# Django settings
DJANGO_SETTINGS_MODULE=core.settings.dev
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Defaults to postgres://appuser:apppassword@localhost:5432/appdb if unset
# Use @db:5432 when running inside Docker Compose
DATABASE_URL=postgres://appuser:apppassword@localhost:5432/appdb

# CORS — add the frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email (override in prod)
DEFAULT_FROM_EMAIL=noreply@example.com

# Superuser (used by `just be-superuser-create`)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Embeddings / RAG
# Set OPENAI_API_KEY to enable real embeddings; omit to use the zero-vector stub
OPENAI_API_KEY=
# Dimensions must match the embedding model (1536 for text-embedding-ada-002)
EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

