# Django settings
DJANGO_SETTINGS_MODULE=core.settings.dev
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Defaults to postgres://appuser:apppassword@localhost:5432/appdb if unset
# Use @db:5432 when running inside Docker Compose
DATABASE_URL=postgres://appuser:apppassword@localhost:5432/appdb

# CORS — add the frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email (override in prod)
DEFAULT_FROM_EMAIL=noreply@example.com

# Superuser (used by `just be-superuser-create`)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Embeddings / RAG
# Local sentence-transformers model — no API key required, weights downloaded once
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Must match the model's output dimension (bge-large-en-v1.5 = 1024)
EMBEDDING_DIMENSIONS=1024
# Override HF cache to use the repo-local models/ folder instead of ~/.cache/huggingface
# Relative path is resolved from the backend/ directory
HF_HOME=../models/huggingface
# Optional. Force embedding device: cuda, cuda:0, mps, cpu.
# Leave unset to auto-detect (uses GPU if available, else CPU).
# Apple Silicon users: set to mps (auto-detect is unreliable for MPS).
# EMBEDDING_DEVICE=cuda

# Anthropic Claude — required only for the /api/embeddings/rag/ endpoint
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-5

